{
  "name": "backend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --hot index.ts",
    "start": "bun run index.ts",
    "build": "bun run prisma:generate",
    "start:prod": "bunx prisma migrate deploy && bun run start",
    "prisma:generate": "bunx prisma generate",
    "prisma:migrate": "bunx prisma migrate dev",
    "prisma:migrate:deploy": "bunx prisma migrate deploy",
    "db:seed": "bunx prisma db seed",
    "import:tanishq": "bun prisma/import-tanishq-csv.ts",
    "sync:store-owners": "bun prisma/sync-store-owners.ts"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "prisma": "^7.4.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.5",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.3.6"
  }
}
